--- /mnt/data/qe6502-tools_v5_orig/qe6502-tools-main/tests/qe6502_tools_sokol_smoke.c	1970-01-01 00:00:00.000000000 +0000
+++ ./tests/qe6502_tools_sokol_smoke.c	2026-06-15 19:43:17.343657598 +0000
@@ -0,0 +1,27 @@
+#define SOKOL_IMPL
+#define SOKOL_DUMMY_BACKEND
+
+#include <sokol_gfx.h>
+
+int main(void)
+{
+    sg_desc desc = {0};
+    sg_setup(&desc);
+
+    if (!sg_isvalid()) {
+        return 1;
+    }
+
+    if (sg_query_backend() != SG_BACKEND_DUMMY) {
+        sg_shutdown();
+        return 2;
+    }
+
+    sg_shutdown();
+
+    if (sg_isvalid()) {
+        return 3;
+    }
+
+    return 0;
+}
