    "node": ">=22"
  },
  "author": "Nikolay Nedelchev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnqe/qe6502.git"
  },
  "homepage": "https://github.com/nnqe/qe6502#readme",
  "bugs": {
    "url": "https://github.com/nnqe/qe6502/issues"
  },
  "keywords": [
    "6502",
    "65c02",
    "emulator",
    "cpu",
    "cycle-accurate",
    "bus-cycle",
    "wasm",
