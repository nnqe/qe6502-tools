set(QE6502_LLVM_ROOT "" CACHE PATH "Optional path to LLVM installation root")

set(_QE6502_LLVM_HINTS)

if(QE6502_LLVM_ROOT)
    list(APPEND _QE6502_LLVM_HINTS "${QE6502_LLVM_ROOT}/bin")
endif()

if(DEFINED ENV{LLVM_ROOT})
    list(APPEND _QE6502_LLVM_HINTS "$ENV{LLVM_ROOT}/bin")
endif()

find_program(_QE6502_BREW_EXECUTABLE brew)

if(_QE6502_BREW_EXECUTABLE)
    execute_process(
        COMMAND "${_QE6502_BREW_EXECUTABLE}" --prefix llvm
        OUTPUT_VARIABLE _QE6502_BREW_LLVM_PREFIX
        OUTPUT_STRIP_TRAILING_WHITESPACE
        ERROR_QUIET
        RESULT_VARIABLE _QE6502_BREW_LLVM_RESULT
    )

    if(_QE6502_BREW_LLVM_RESULT EQUAL 0 AND _QE6502_BREW_LLVM_PREFIX)
        list(APPEND _QE6502_LLVM_HINTS "${_QE6502_BREW_LLVM_PREFIX}/bin")
    endif()
endif()

set(_QE6502_CLANG_NAMES clang)
set(_QE6502_LLVM_AR_NAMES llvm-ar)
set(_QE6502_LLVM_RANLIB_NAMES llvm-ranlib)
set(_QE6502_WASM_LD_NAMES wasm-ld)

foreach(_QE6502_LLVM_VERSION RANGE 30 10 -1)
    list(APPEND _QE6502_CLANG_NAMES "clang-${_QE6502_LLVM_VERSION}")
    list(APPEND _QE6502_LLVM_AR_NAMES "llvm-ar-${_QE6502_LLVM_VERSION}")
    list(APPEND _QE6502_LLVM_RANLIB_NAMES "llvm-ranlib-${_QE6502_LLVM_VERSION}")
    list(APPEND _QE6502_WASM_LD_NAMES "wasm-ld-${_QE6502_LLVM_VERSION}")
endforeach()

find_program(QE6502_CLANG
    NAMES ${_QE6502_CLANG_NAMES}
    HINTS ${_QE6502_LLVM_HINTS}
    REQUIRED
)

find_program(QE6502_LLVM_AR
    NAMES ${_QE6502_LLVM_AR_NAMES}
    HINTS ${_QE6502_LLVM_HINTS}
    REQUIRED
)

find_program(QE6502_LLVM_RANLIB
    NAMES ${_QE6502_LLVM_RANLIB_NAMES}
    HINTS ${_QE6502_LLVM_HINTS}
    REQUIRED
)

find_program(QE6502_WASM_LD
    NAMES ${_QE6502_WASM_LD_NAMES}
    HINTS ${_QE6502_LLVM_HINTS}
    REQUIRED
)

message(STATUS "QE6502 LLVM clang: ${QE6502_CLANG}")
message(STATUS "QE6502 LLVM ar: ${QE6502_LLVM_AR}")
message(STATUS "QE6502 LLVM ranlib: ${QE6502_LLVM_RANLIB}")
message(STATUS "QE6502 LLVM wasm-ld: ${QE6502_WASM_LD}")

unset(_QE6502_LLVM_HINTS)
unset(_QE6502_BREW_EXECUTABLE)
unset(_QE6502_BREW_LLVM_PREFIX)
unset(_QE6502_BREW_LLVM_RESULT)

unset(_QE6502_CLANG_NAMES)
unset(_QE6502_LLVM_AR_NAMES)
unset(_QE6502_LLVM_RANLIB_NAMES)
unset(_QE6502_WASM_LD_NAMES)
unset(_QE6502_LLVM_VERSION)
