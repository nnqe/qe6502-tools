{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug_native",
      "displayName": "Debug Native",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug_native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_ENABLE_WERROR": "ON"
      }
    },
    {
      "name": "release_native",
      "displayName": "Release Native",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release_native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_ENABLE_WERROR": "ON"
      }
    },
    {
      "name": "debug_wasm",
      "displayName": "Debug WebAssembly",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug_wasm",
      "toolchainFile": "${sourceDir}/cmake/toolchains/wasm32-unknown-unknown-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QE6502_BUILD_WASM": "ON",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_ENABLE_WERROR": "ON"
      }
    },
    {
      "name": "release_wasm",
      "displayName": "Release WebAssembly",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release_wasm",
      "toolchainFile": "${sourceDir}/cmake/toolchains/wasm32-unknown-unknown-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QE6502_BUILD_WASM": "ON",
        "QE6502_BUILD_TESTS": "ON",
        "QE6502_ENABLE_WERROR": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug_native",
      "configurePreset": "debug_native"
    },
    {
      "name": "release_native",
      "configurePreset": "release_native"
    },
    {
      "name": "debug_wasm",
      "configurePreset": "debug_wasm"
    },
    {
      "name": "release_wasm",
      "configurePreset": "release_wasm"
    }
  ]
}
